rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── สลิปค่าใช้จ่ายเพิ่มเติม ────────────────────────────────────────────
    // path: expenseSlips/{lineUserId}/{fileName}
    match /expenseSlips/{lineUserId}/{fileName} {
      allow read: if request.auth != null
        && (
          request.auth.token.firebase.sign_in_provider == 'password'
          || (request.auth.uid == lineUserId && request.auth.token.lineUser == true)
        );
      allow write: if request.auth != null
        && request.auth.uid == lineUserId
        && request.auth.token.lineUser == true
        && request.resource.size <= 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ── รูปสำเนาบัตรประชาชน ────────────────────────────────────────────────
    // path: idCards/{lineUserId}/id_card.{ext}
    match /idCards/{lineUserId}/{fileName} {

      // Admin อ่านได้ทั้งหมด; freelancer (LINE custom token, uid = lineUserId) อ่านได้เฉพาะโฟลเดอร์ของตัวเอง
      allow read: if request.auth != null
        && (
          request.auth.token.firebase.sign_in_provider == 'password'
          || (request.auth.uid == lineUserId && request.auth.token.lineUser == true)
        );

      // Freelancer อัพโหลดได้เฉพาะของตัวเอง
      // ต้องเป็นไฟล์รูป ขนาดไม่เกิน 10 MB
      allow write: if request.auth != null
        && request.auth.uid == lineUserId
        && request.auth.token.lineUser == true
        && request.resource.size <= 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

  }
}
